# PostHog Analytics - copy to .env.local and fill in from posthog.com project settings
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Formspree contact form - get endpoint from formspree.io (e.g. https://formspree.io/f/xxxxx)
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your_form_id

